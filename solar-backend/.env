# ─── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=""
DB_NAME=solar_db

# ─── Server ─────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── JWT (for admin auth) ────────────────────────────────────
JWT_SECRET=solar_tech_super_secret_key_change_in_production
JWT_EXPIRES=7d

# ─── Email (Nodemailer via Gmail SMTP) ──────────────────────
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=SolarTech Pro <noreply@solartechpro.in>

# ─── Google Maps ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
